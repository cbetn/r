#3. Circular Linked List Implementation
class Node:
    def __init__(self, data):
        self.data = data
        self.next = None
class CircularLinkedList:
    def __init__(self):
        self.tail = None
    def insert_end(self, data):  # O(1)
        new_node = Node(data)
        if not self.tail:
            self.tail = new_node
            new_node.next = new_node
        else:
            new_node.next = self.tail.next
            self.tail.next = new_node
            self.tail = new_node
        return new_node
    def insert_before(self, target_node, data):  # O(n) or O(1) with tail
        """Insert before target_node in circular list"""
        if target_node is None or not self.tail:
            print("Empty list or invalid target")
            return None
        new_node = Node(data)
        # Special case: before tail (becomes new tail)
        if target_node == self.tail:
            new_node.next = self.tail.next
            self.tail.next = new_node
            self.tail = new_node
        return new_node
        # Traverse to predecessor (could cache prev for O(1))
        curr = self.tail
        while curr.next != target_node:
            curr = curr.next
            if curr == self.tail:  # Full circle, not found
                print("Target not found")
                return None
            new_node.next = target_node
            curr.next = new_node
            return new_node
    def delete_head(self):  # O(1)
        if self.tail:
            if self.tail.next == self.tail:
                self.tail = None
           else:
                self.tail.next = self.tail.next.next
    def print_list(self):
        if not self.tail:
            print("Empty")
            return curr = self.tail.next
        vals = []
        while True:
            vals.append(str(curr.data))
            curr = curr.next
            if curr == self.tail.next:
                break
            print(" <-> ".join(vals) + " (circular)")
