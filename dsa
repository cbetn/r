#Stack Implementation using Array
class Stack:
    """Array-based Stack: LIFO with fixed capacity. O(1) operations."""
    def __init__(self, capacity):
        """Time: O(1), Space: O(n)"""
        self.capacity = capacity
        self.stack = [None] * capacity
        self.top = -1
    def push(self, item):
        """Push to top. Time: O(1)"""
        if self.top == self.capacity - 1:
             print("Stack Overflow!")
             return False
        self.top += 1
        self.stack[self.top] = item
        return True
    def pop(self):
        """Pop from top. Time: O(1)"""
        if self.top == -1:
            print("Stack Underflow!")
            return None
        item = self.stack[self.top]
        self.top -= 1
        return item
    def peek(self):
        """Top element. Time: O(1)"""
        if self.top == -1:
            return None
        return self.stack[self.top]
    def is_empty(self):
        """Time: O(1)"""
        return self.top == -1
    def size(self):
        """Time: O(1)"""
        return self.top + 1
    if __name__ == "__main__":
        sizes = [10, 100, 1000, 10000]
        for n in sizes:
            print(f"\n--- Testing Stack capacity {n}---")
            s= Stack(n)
            for i in range(n):
                s.push(i)
                print(f"Size after {n} pushes: {s.size()}")
            for i in range(n//2):
                s.pop()
                print(f"Size after {n//2} pops: {s.size()}")
# Complexity: Push/Pop/Peek/Size/isEmpty: O(1), Space: O(n)
#2. Circular Queue Implementation using Array
class Queue:
    """Circular Array Queue: FIFO. O(1) operations using modulo."""
    def __init__(self, capacity):
        """Time: O(1), Space: O(n)"""
        self.capacity = capacity
        self.queue = [None] * capacity
        self.front = self.rear = -1
    def enqueue(self, item):
        """Add to rear. Time: O(1)"""
        if (self.rear + 1) % self.capacity == self.front:
            print("Queue Overflow!")
            return False
        if self.front == -1:
            self.front = 0
            self.rear = (self.rear + 1) % self.capacity
            self.queue[self.rear] = item
            return True
    def dequeue(self):
        """Remove from front. Time: O(1)"""
        if self.front == -1:
            print("Queue Underflow!")
            return None
        item = self.queue[self.front]
        if self.front == self.rear:
            self.front = self.rear = -1
        else:
            self.front = (self.front + 1) % self.capacity
            return item
    def is_empty(self):
        """Time: O(1)"""
        return self.front == -1
    def size(self):
        """Time: O(1)"""
    if self.front == -1:
        return 0
    return (self.rear - self.front + self.capacity) % self.capacity + 1
