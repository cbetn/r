import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.ensemble import IsolationForest

# --- BOX PLOT METHOD (IQR) ---
print("\n--- Box Plot Method ---")
# 1. Visualize with a Box Plot
plt.figure(figsize=(6,4))
sns.boxplot(x=df['values'])
plt.title("Box Plot of Values")
plt.show()

# 2. Identify thresholds using IQR
Q1 = df['values'].quantile(0.25)
Q3 = df['values'].quantile(0.75)
IQR = Q3 - Q1
lower_bound = Q1 - 1.5 * IQR
upper_bound = Q3 + 1.5 * IQR

# 3. Eliminate outliers
df_clean_iqr = df[(df['values'] >= lower_bound) & (df['values'] <= upper_bound)]
print(f"Lower Bound: {lower_bound}, Upper Bound: {upper_bound}")
print("Data after removing outliers (IQR):\n", df_clean_iqr)


# --- SCATTER PLOT METHOD ---
print("\n--- Scatter Plot Method ---")
# Adding a second column for plotting
df['index'] = df.index

# 1. Draw scatter plot
plt.figure(figsize=(6,4))
