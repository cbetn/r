# Uses SLL for explicit stack in iterative DFS. 0=free, 1=wall. Returns path.
from singly_linked_list import SinglyLinkedList, Node  # Reuse SLL as stack
class Graph:
    def __init__(self, n):
        self.n = n
        self.adj = [[] for _ in range(n)]
    def add_edge(self, u, v):
        self.adj[u].append(v)
        self.adj[v].append(u)  # Undirected
    def dfs_iterative(graph: Graph, start):
        """Iterative DFS using SLL as explicit stack O(V+E)"""
        visited = [False] * graph.n
        stack = SinglyLinkedList()
        stack.insert_end(start)
        path = []
        while stack.head:  # Stack not empty
            node = stack.head.data
            stack.delete_front()
            if not visited[node]:
                visited[node] = True
                path.append(node)
                # Push unvisited neighbors (reverse order for sim)
                for nei in reversed(graph.adj[node]):
                    if not visited[nei]:
                        stack.insert_front(nei)
                        return path
