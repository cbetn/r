#GRUBBS TEST
from scipy.stats import t

def grubbs_test(x):
    N = len(x)
    mean_x = np.mean(x)
    std_x = np.std(x)

    G = max(abs(x - mean_x)) / std_x

    t_val = t.ppf(1 - 0.05/(2*N), N-2)
    threshold = ((N-1)/np.sqrt(N)) * np.sqrt(t_val*2 / (N-2 + t_val*2))

    if G > threshold:
        print("Outlier Detected")
    else:
        print("No Outlier")

